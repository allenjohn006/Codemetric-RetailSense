DATABASE_URL=postgresql://retailsense_user:retailsense_password@db:5432/retailsense
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# File upload settings
MAX_UPLOAD_SIZE_MB=500
UPLOAD_DIR=/tmp/retailsense_uploads

# Demo account (seeded on startup)
DEMO_EMAIL=demo@retailsense.io
DEMO_PASSWORD=Demo@RetailSense2024
